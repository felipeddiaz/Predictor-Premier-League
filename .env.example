# The Odds API — get free key at https://the-odds-api.com
ODDS_API_KEY=your_key_here
# Intervalo de refresco de cuotas en segundos (default: 43200 = 12h)
ODDS_REFRESH_INTERVAL=43200

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1

# CORS Configuration
CORS_ORIGINS=["*"]

# Predictor Configuration
PREDICTOR_CACHE_SIZE=100
PREDICTOR_TIMEOUT=30

# Logging
LOG_LEVEL=INFO

# Feature Flags
ENABLE_GAMEWEEK_PREDICTIONS=true
ENABLE_TEAM_STATS=true
ENABLE_HISTORY_TRACKING=false
ENABLE_UTILS=true
