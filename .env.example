# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_WORKERS=1

# CORS Configuration
CORS_ORIGINS=["*"]

# Predictor Configuration
PREDICTOR_CACHE_SIZE=100
PREDICTOR_TIMEOUT=30

# Logging
LOG_LEVEL=INFO

# Feature Flags
ENABLE_GAMEWEEK_PREDICTIONS=true
ENABLE_TEAM_STATS=true
ENABLE_HISTORY_TRACKING=false
ENABLE_UTILS=true
